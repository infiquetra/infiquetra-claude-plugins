{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Plugin Manifest",
  "description": "Schema for Claude Code plugin.json manifest files",
  "type": "object",
  "required": ["version", "name", "description", "author"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9]+)?$",
      "description": "Semantic version (e.g., 1.0.0, 1.0.0-beta)",
      "examples": ["1.0.0", "2.1.3", "1.0.0-alpha"]
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "description": "Human-readable plugin name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Brief description of plugin functionality"
    },
    "author": {
      "description": "Plugin author information",
      "oneOf": [
        {
          "type": "string",
          "description": "Author name as string"
        },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Author name"
            },
            "email": {
              "type": "string",
              "format": "email",
              "description": "Author email address"
            },
            "organization": {
              "type": "string",
              "description": "Author organization"
            }
          }
        }
      ]
    },
    "license": {
      "type": "string",
      "description": "License identifier (e.g., MIT, Apache-2.0)",
      "examples": ["MIT", "Apache-2.0", "GPL-3.0"]
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Plugin homepage URL"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "Repository URL"
    },
    "bugs": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Issue tracker URL"
        }
      }
    },
    "engines": {
      "type": "object",
      "description": "Required engine versions",
      "properties": {
        "claude": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+$",
          "description": "Minimum Claude Code version"
        },
        "python": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+(\\.\\d+)?$",
          "description": "Python version requirement"
        },
        "node": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+$",
          "description": "Node.js version requirement"
        },
        "bash": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+$",
          "description": "Bash version requirement"
        }
      }
    },
    "main": {
      "type": "string",
      "description": "Main entry point script path",
      "pattern": "^src/.+\\.(py|sh|js|ts)$"
    },
    "scripts": {
      "type": "object",
      "description": "Named script commands",
      "patternProperties": {
        "^[a-z0-9-]+$": {
          "type": "string",
          "description": "Script command"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Runtime dependencies",
      "patternProperties": {
        "^.+$": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+$",
          "description": "Dependency version"
        }
      }
    },
    "devDependencies": {
      "type": "object",
      "description": "Development dependencies",
      "patternProperties": {
        "^.+$": {
          "type": "string",
          "pattern": "^>=?\\d+\\.\\d+\\.\\d+$",
          "description": "Dependency version"
        }
      }
    },
    "keywords": {
      "type": "array",
      "description": "Search keywords for plugin discovery",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true
    },
    "config": {
      "type": "object",
      "description": "Plugin-specific configuration"
    },
    "permissions": {
      "type": "array",
      "description": "Required permissions for plugin operation",
      "items": {
        "type": "string",
        "enum": [
          "github:repo",
          "github:admin",
          "aws:secretsmanager",
          "aws:dynamodb",
          "aws:lambda",
          "aws:cloudformation",
          "filesystem:read",
          "filesystem:write",
          "network:http",
          "slack:post"
        ]
      },
      "uniqueItems": true
    },
    "category": {
      "type": "string",
      "enum": ["compliance", "development", "infrastructure", "automation"],
      "description": "Plugin category"
    },
    "timeSavings": {
      "type": "string",
      "description": "Estimated time savings per use",
      "pattern": "^\\d+-\\d+ (minutes|hours).*$"
    }
  }
}
